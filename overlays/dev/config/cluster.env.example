# Copy to cluster.env and edit for your dev cluster.
# Convention: api/app/business subdomains under one wildcard TLS cert (*.DOMAIN).
#
# Quick start (from overlays/dev/config/):
#   ./generate-cluster-env.sh your.domain.example > cluster.env
#
# GATEWAY_WILDCARD_HOST must match the wildcard certificate on the Gateway listener.

GATEWAY_WILDCARD_HOST=*.your.domain.example
API_HOST=api.your.domain.example
APP_HOST=app.your.domain.example
BUSINESS_HOST=business.your.domain.example
PUBLIC_API_BASE_URL=https://api.your.domain.example
APP_ORIGIN=https://app.your.domain.example
BUSINESS_ORIGIN=https://business.your.domain.example
MEDIA_PUBLIC_BASE_URL=https://api.your.domain.example
MINIO_CORS_ALLOW_ORIGIN=https://app.your.domain.example,https://business.your.domain.example
