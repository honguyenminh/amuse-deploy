# Workload Identity + Key Vault — copy from `terraform output` after apply.
AMUSE_WORKLOAD_IDENTITY_CLIENT_ID=e0bce6d2-c4b8-4bd0-996a-bf89ea397592
KEY_VAULT_URI=https://uit-amuse-kv-c24d8071.vault.azure.net/
# Gateway → AGC (BYO): copy from `terraform output -raw agc_alb_id` and `agc_frontend_name` in tfvars.
AGC_ALB_ARM_ID=/subscriptions/5056a04f-bd2c-496c-aed8-cdb4b6dc7fbb/resourceGroups/uit-amuse-staging/providers/Microsoft.ServiceNetworking/trafficControllers/uit-amuse-agc
AGC_ALB_FRONTEND=amuse-staging-fe
GATEWAY_WILDCARD_HOST=*.amuse.m8.io.vn
API_HOST=api.amuse.m8.io.vn
APP_HOST=amuse.m8.io.vn
BUSINESS_HOST=business.amuse.m8.io.vn
PUBLIC_API_BASE_URL=https://api.amuse.m8.io.vn
APP_ORIGIN=https://amuse.m8.io.vn
BUSINESS_ORIGIN=https://business.amuse.m8.io.vn
# Public CDN / R2 custom domain for cover art (must match Key Vault amuse-r2-public-base-url).
MEDIA_PUBLIC_BASE_URL=https://media.amuse.m8.io.vn
# Comma-separated browser origins for R2 bucket CORS (see infrastructure/cloudflare/README.md).
MEDIA_CORS_ORIGINS=https://amuse.m8.io.vn,https://business.amuse.m8.io.vn
