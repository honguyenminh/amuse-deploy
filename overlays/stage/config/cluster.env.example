# Copy to cluster.env and fill from `terraform output` after `terraform apply`.
# cluster.env is NOT synced to amuse-deploy by CI — edit it in the deploy repo for your cluster.

# Workload Identity (terraform output amuse_workload_identity_client_id)
AMUSE_WORKLOAD_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Key Vault (terraform output key_vault_uri — no trailing path)
KEY_VAULT_URI=https://REPLACE_KV_NAME.vault.azure.net/

# AGC BYO (terraform output -raw agc_alb_id; agc_frontend_name from tfvars)
AGC_ALB_ARM_ID=/subscriptions/SUB/resourceGroups/RG/providers/Microsoft.ServiceNetworking/trafficControllers/NAME
AGC_ALB_FRONTEND=amuse-staging-fe

GATEWAY_WILDCARD_HOST=*.amuse.m8.io.vn
API_HOST=api.amuse.m8.io.vn
APP_HOST=amuse.m8.io.vn
BUSINESS_HOST=business.amuse.m8.io.vn
PUBLIC_API_BASE_URL=https://api.amuse.m8.io.vn
APP_ORIGIN=https://amuse.m8.io.vn
BUSINESS_ORIGIN=https://business.amuse.m8.io.vn
MEDIA_PUBLIC_BASE_URL=https://media.amuse.m8.io.vn
MEDIA_CORS_ORIGINS=https://amuse.m8.io.vn,https://business.amuse.m8.io.vn
